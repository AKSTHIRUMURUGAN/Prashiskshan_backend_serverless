# Server
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/prashiskshan
MONGODB_TEST_URI=mongodb://localhost:27017/prashiskshan_test

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Google Gemini AI
# Available models: gemini-2.0-flash (recommended for most use cases)
# Note: Older models (gemini-1.5-flash, gemini-1.5-flash-001, gemini-pro) are deprecated
GEMINI_API_KEY=
GEMINI_MODEL_FLASH=gemini-2.0-flash

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=prashiskshan-storage

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=prashiskshan-r2
R2_PUBLIC_URL=https://cdn.example.com

# Oracle Object Storage
ORACLE_REGION=ap-hyderabad-1
ORACLE_NAMESPACE=
ORACLE_ACCESS_KEY_ID=
ORACLE_SECRET_ACCESS_KEY=
ORACLE_BUCKET=prashiskshan-oracle
ORACLE_ENDPOINT=

# ImageKit
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# Email Providers
BREVO_API_KEY=
BREVO_FROM_EMAIL=noreply@prashiskshan.com
BREVO_FROM_NAME=Prashiskshan

MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM_EMAIL=noreply@prashiskshan.com

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# Sentry
SENTRY_DSN=

# Security
JWT_SECRET=
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# AI Rate Limits
AI_INTERVIEW_DAILY_LIMIT=3
AI_CHATBOT_DAILY_LIMIT=50
AI_SUMMARY_DAILY_LIMIT=10
