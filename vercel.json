{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "crons": [
    {
      "path": "/api/cron/metrics",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/credit-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/deadline-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/expired-internships",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/analytics-snapshot",
      "schedule": "0 2 * * *"
    }
  ]
}
